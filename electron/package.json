{
  "name": "epigrader",
  "version": "1.0.0",
  "description": "EpiGrader - AI-Powered Code Grading for Epitech",
  "main": "main.js",
  "homepage": "https://github.com/LyannEpitech/epigrader",
  "repository": {
    "type": "git",
    "url": "https://github.com/LyannEpitech/epigrader.git"
  },
  "author": {
    "name": "EpiGrader",
    "email": "contact@epigrader.dev"
  },
  "scripts": {
    "start": "electron .",
    "build": "npm run build:backend && npm run build:frontend && npm run build:electron",
    "build:backend": "cd ../backend && npm run build",
    "build:frontend": "cd ../frontend && npm run build",
    "build:electron": "electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:win": "npm run build && electron-builder --win --publish=never",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.epigrader.app",
    "productName": "EpiGrader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "loading.html"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*.js", "**/*.json", "!**/*.d.ts", "!**/*.d.ts.map", "!**/*.js.map"]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "backend/frontend/dist"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*", "!**/{*.d.ts,*.ts,tsconfig.json}"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EpiGrader",
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "EpiGrader-Portable-${version}.exe"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Education"
    },
    "asar": false
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}