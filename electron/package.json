{
  "name": "epigrader",
  "version": "1.0.0",
  "description": "EpiGrader - AI-Powered Code Grading for Epitech",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:backend && npm run build:frontend && npm run build:electron",
    "build:backend": "cd ../backend && npm run build",
    "build:frontend": "cd ../frontend && npm run build",
    "build:electron": "electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:win": "npm run build && electron-builder --win --publish=never",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.epigrader.app",
    "productName": "EpiGrader",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "loading.html",
      "assets/**/*",
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "backend/frontend/dist"
      }
    ],
    "extraResources": [
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*", "!**/{*.d.ts,*.ts,tsconfig.json}"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EpiGrader",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "EpiGrader-Portable-${version}.exe"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icons",
      "category": "Education"
    },
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}