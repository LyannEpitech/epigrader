{
  "name": "epigrader-standalone",
  "version": "1.0.0",
  "description": "EpiGrader Standalone Executable",
  "main": "backend/index.js",
  "bin": "backend/index.js",
  "pkg": {
    "scripts": [
      "backend/**/*.js"
    ],
    "assets": [
      "frontend/dist/**/*",
      "backend/data/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64",
      "node18-macos-x64"
    ]
  },
  "scripts": {
    "build:exe": "pkg . --out-path=release/"
  }
}